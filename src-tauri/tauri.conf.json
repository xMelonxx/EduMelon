{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EduMelon",
  "version": "0.1.6",
  "identifier": "com.edumelon.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EduMelon",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/xMelonxx/EduMelon/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkxMjY1NTA3MDNCQjFCOUQKUldTZEc3c0RCMVVta1lpVFFXOEtjOVFTRHArNi9xN1FtZWdCZHhicFNtTjJDM0JGOXJzOFVUOTkK"
    }
  }
}
